# 密钥和环境变量
.env
*.key
config/models.json

# Benchmark 产物（每次运行生成，不入库；只保留 .gitkeep 占位）
benchmarks/results/*
benchmarks/reports/*
benchmarks/logs/*
benchmarks/running/
!benchmarks/results/.gitkeep
!benchmarks/reports/.gitkeep
!benchmarks/logs/.gitkeep

